# AgentPay 代理 环境变量配置
# 复制此文件为 .env，填入你的真实凭证

# ========== 支付宝 AI 付费凭证（必填） ==========
AIPAY_APP_ID=请替换为你的APP_ID
AIPAY_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n请替换为你的应用私钥\n-----END PRIVATE KEY-----
AIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n请替换为你的支付宝公钥\n-----END PUBLIC KEY-----
AIPAY_SELLER_ID=请替换为你的2088商户ID
AIPAY_SERVICE_ID=请替换为你的SERVICE_ID

# ========== 可选：商户展示名称 ==========
AIPAY_SELLER_NAME=我的智能体服务

# ========== 代理模式（必填） ==========
# 商户业务 Agent 的地址
AIPAY_UPSTREAM_URL=http://localhost:9000

# ========== 可选：监听端口 ==========
# AIPAY_LISTEN_PORT=8080

# ========== 可选：从文件读取密钥（优先级高于上方环境变量） ==========
# AIPAY_PRIVATE_KEY_FILE=/path/to/private_key.pem
# AIPAY_PUBLIC_KEY_FILE=/path/to/alipay_public_key.pem

# ========== 可选：支付宝网关 ==========
# AIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
